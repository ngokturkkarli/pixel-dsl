  rect 5,50 91,50 d
  rect 6,57 90,57 q
  rect 6,58 90,58 Q
  rect 7,63 89,63 d
  rect 9,64 87,64 D
  pixel 5,63 D
  pixel 91,63 D

  // Upper gunports
  rect 11,52 13,54 K
  rect 17,52 19,54 K
  rect 23,52 25,54 K
