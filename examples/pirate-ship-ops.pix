// Pirate galleon — sails set forward (parallelogram bands leaning toward the
// bow as if caught by a tailwind). Authored entirely with shape ops.

palette pirate {
  sky    s #87ceeb
  skylo  S #5fa0d0
  sun    y #ffd700
  sunhi  L #fff8b0
  white  w #ffffff
  cloud  C #dde8f0
  sail   c #f5e6c4
  M  M #d4b888
  sailg  g #8a6a3d
  masthi u #5c3820
  mast   o #2a1810
  rope   e #3a1f0c
  hullhi H #b06e3a
  hull   h #7a4220
  hulld  d #4a2812
  hullx  D #2a1408
  goldhi q #ffd454
  gold   Q #b08a20
  red    r #c0392b
  black  K #0a0503
  sea    b #2a6dba
  sealo  n #13407a
  seax   N #0a2452
  foam   f #b8dff5
}

