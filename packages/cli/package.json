{
	"name": "@pixel-dsl/cli",
	"version": "0.1.0",
	"description": "Command-line interface for Pixel-DSL — compile .pix sources to PNG sprites.",
	"keywords": [
		"pixel-art",
		"sprite",
		"dsl",
		"cli",
		"png",
		"llm"
	],
	"author": "msyavuz <salih.yavuz@proton.me>",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/msyavuz/pixel-dsl.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/msyavuz/pixel-dsl#readme",
	"bugs": {
		"url": "https://github.com/msyavuz/pixel-dsl/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"pixel-dsl": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b && chmod +x dist/index.js",
		"dev": "tsx src/index.ts",
		"test": "vitest",
		"typecheck": "tsc -b",
		"lint": "biome lint --write",
		"format": "biome check --write"
	},
	"dependencies": {
		"@pixel-dsl/core": "workspace:*",
		"commander": "^14.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.7.0"
	}
}
