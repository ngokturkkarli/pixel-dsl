{
	"name": "@pixel-dsl/cli",
	"version": "1.0.0",
	"description": "Command-line interface for Pixel-DSL",
	"type": "module",
	"bin": {
		"pixel-dsl": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b && chmod +x dist/index.js",
		"dev": "tsx src/index.ts",
		"test": "vitest",
		"typecheck": "tsc -b",
		"lint": "biome lint --write",
		"format": "biome check --write"
	},
	"dependencies": {
		"@pixel-dsl/core": "workspace:*",
		"commander": "^14.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.7.0"
	}
}
