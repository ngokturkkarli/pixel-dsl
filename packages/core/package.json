{
	"name": "@pixel-dsl/core",
	"version": "0.1.0",
	"description": "Parser and deterministic PNG renderer for Pixel-DSL, an LLM-friendly pixel-art sprite language.",
	"keywords": [
		"pixel-art",
		"sprite",
		"dsl",
		"parser",
		"renderer",
		"png",
		"llm",
		"deterministic"
	],
	"author": "msyavuz <salih.yavuz@proton.me>",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/msyavuz/pixel-dsl.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/msyavuz/pixel-dsl#readme",
	"bugs": {
		"url": "https://github.com/msyavuz/pixel-dsl/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "vitest",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome lint --write",
		"format": "biome check --write",
		"gen:goldens": "tsx scripts/gen-goldens.ts"
	},
	"type": "module",
	"dependencies": {
		"chevrotain": "^12.0.0",
		"pngjs": "^7.0.0"
	},
	"devDependencies": {
		"@types/pngjs": "^6.0.5"
	}
}
